{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=forwarder.db"
  },
  "akka": {
    "actor": {
      "provider": "Akka.Remote.RemoteActorRefProvider, Akka.Remote"
    },

    "remote": {
      "dot-netty.tcp": {
        "hostname": "localhost",
        "port": 4054
      }
    }

  },
    "AllowedHosts": "*"
  }
