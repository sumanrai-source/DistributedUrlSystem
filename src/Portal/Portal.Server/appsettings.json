{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "akka": {
    "actor": {
      "provider": "Akka.Remote.RemoteActorRefProvider, Akka.Remote"
    },
    "remote": {
      "dot-netty.tcp": {
        "hostname": "localhost",
        "port": 4053
      }
    }
  },
  "Services": {
    "Assigner": {
      "BaseUrl": "http://localhost:5137"
    },
    "Forwarder": {
      "BaseUrl": "http://localhost:5240"
    }
  },
  "AllowedHosts": "*"
}
